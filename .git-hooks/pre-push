#!/usr/bin/env bash
# Pre-push gate + deploy for checkboxes.
#
# Thin shim over the shared fleet gate library (dotagents/gate/gate-lib.sh): the
# ~100 lines of boilerplate every repo shares — push-ref parsing, the gitleaks
# secrets scan, markdown-lint-on-change, the doc-only fast path, the working-tree
# guards, and run_step (silent on green, full output on red) — live in the lib.
# This file declares only what is checkboxes-specific: the quality steps and the
# Vercel production deploy. We deploy from the hook because the Vercel↔GitHub git
# integration is disconnected — the push is the deploy trigger, so a failed deploy
# fails the push (tight feedback, nothing half-shipped). Docs-only pushes take the
# lib's fast path that skips both gate and deploy.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; cd "$ROOT"
# shellcheck source=/dev/null
source "${DOTAGENTS_GATE_LIB:-$HOME/code/dotagents/gate/gate-lib.sh}" || {
  echo "✗ dotagents gate-lib not found (expected ~/code/dotagents/gate/gate-lib.sh) — re-run install-local-agent-runtime.sh." >&2
  exit 1
}

gate_begin "checkboxes" deploys   # parse push; gitleaks; md-lint; doc-only fast path; banner; ERR trap
gate_require_clean_tree           # refuse dirty tree / pushed-SHA≠HEAD / non-fast-forward

gate_require_node                 # enforce the pinned Node (.nvmrc), not whatever's on PATH

# --- Quality gate (run_step: silent on green, full output + abort on red) ---
run_step "dep grounding" gate_check_dep_grounding .git-hooks/pre-push scripts/*.sh
run_step "lint"        npm run lint
run_step "yaml lint"   npm run check:yaml
run_step "astro check" npx --no-install astro check
run_step "build"       npm run build

# --- Deploy: production deploy to Vercel (remote build; streams) ---
gate_deploy_vercel team_T8yHg0aDz7nCbyBgJh5a2saR prj_Qy2iDBHuQ0n16tuT1vBmeIrgKkxr
echo "✓ pre-push gate + deploy complete"
