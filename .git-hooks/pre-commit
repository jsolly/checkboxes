#!/usr/bin/env bash
# Pre-commit GATE for checkboxes (gate-only — this hook does NOT deploy).
#
# Thin shim over the shared fleet gate library (dotagents/gate/gate-lib.sh): the
# ~100 lines of boilerplate every repo shares — the staged secrets scan,
# markdown-lint-on-change, the doc-only fast path, the commit-context guards,
# and run_step (silent on green, full output on red) — live in the lib.
# This file declares only checkboxes-specific quality steps. The gate fires on
# every commit; production deploy is owned by Vercel's GitHub integration after
# the commit lands on main.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"; cd "$ROOT"
# shellcheck source=/dev/null
source "${DOTAGENTS_GATE_LIB:-$HOME/code/dotagents/gate/gate-lib.sh}" || {
  echo "✗ dotagents gate-lib not found (expected ~/code/dotagents/gate/gate-lib.sh) — re-run install-local-agent-runtime.sh." >&2
  exit 1
}

gate_begin_commit "checkboxes"    # staged gitleaks; md-lint; doc-only fast path; skip on merge/amend; banner; ERR trap
gate_require_node                 # enforce the pinned Node (.nvmrc), not whatever's on PATH

# --- Quality gate (run_step: silent on green, full output + abort on red) ---
run_step "dep grounding" gate_check_dep_grounding .git-hooks/pre-commit scripts/*.sh
run_step "biome ci"     npx --no-install biome ci . --error-on-warnings
run_step "yaml lint"   npm run check:yaml
run_step "actionlint"             npm run check:actions
run_step "astro check (types)" npm run check:ts
run_step "build"       npm run build

echo "✓ pre-commit gate passed — commit will land; Vercel deploys via GitHub integration after merge to main."
