#!/usr/bin/env bash
set -euo pipefail

# BEGIN dotagents fleet pre-commit guard
ROOT="$(git rev-parse --show-toplevel)"
if [ -x "$ROOT/.agents/scripts/fleet-precommit-check.sh" ]; then
  bash "$ROOT/.agents/scripts/fleet-precommit-check.sh" || exit 1
fi
# END dotagents fleet pre-commit guard

error_handler() {
  printf '\n\033[0;31m✗ Commit aborted: One or more checks failed.\033[0m\n'
  printf 'Check the output above for details. Fix the issues, then try committing again.\n'
}
trap error_handler ERR

echo "Ensuring staged files are linted/formatted..."
npm run lint-staged

echo "Running Biome CI..."
npx biome ci .

echo "Running Astro check..."
npx astro check

echo "Running tests..."
npm run test

echo "Running production build..."
npm run build
