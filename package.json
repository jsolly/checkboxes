{
	"name": "static-astro-website",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"deploy": "VERCEL_ORG_ID=team_T8yHg0aDz7nCbyBgJh5a2saR VERCEL_PROJECT_ID=prj_Qy2iDBHuQ0n16tuT1vBmeIrgKkxr vercel deploy --prod --yes",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "if [ -z \"$CI\" ] && git rev-parse --git-dir >/dev/null 2>&1; then git config core.hooksPath .git-hooks; fi",
		"lint": "biome lint .",
		"lint-fix": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"check:md": "bash scripts/lint-md.sh",
		"check:yaml": "uvx yamllint@1.38.0 .",
		"generate-stats": "tsx src/utils/generate-stats.ts",
		"test": "tsx --test \"tests/**/*.test.ts\"",
		"lint-staged": "lint-staged"
	},
	"lint-staged": {
		".agents/**": [],
		"!(.agents)/**/*": [
			"biome check --no-errors-on-unmatched --write"
		]
	},
	"overrides": {
		"path-to-regexp": ">=6.3.0",
		"tar-fs": ">=3.0.9",
		"brace-expansion": ">=2.0.2",
		"tar": ">=7.5.11",
		"defu": ">=6.1.5",
		"devalue": ">=5.3.2",
		"fast-uri": ">=3.1.1",
		"glob": ">=10.5.0",
		"lodash": ">=4.18.0",
		"minimatch": ">=9.0.6",
		"rollup": ">=4.59.0",
		"h3": ">=1.15.8",
		"picomatch": ">=2.3.2",
		"undici": ">=6.24.0",
		"vite": ">=6.4.2 <7.0.0"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/prism": "^3.2.0",
		"@astrojs/react": "^4.1.2",
		"@astrojs/sitemap": "^3.2.1",
		"@astrojs/svelte": "^7.0.2",
		"@astrojs/tailwind": "^5.1.4",
		"@astrojs/vercel": "^8.0.1",
		"@astrojs/vue": "^6.0.1",
		"@google/genai": "^2.6.0",
		"@hotwired/stimulus": "^3.2.2",
		"@types/alpinejs": "^3.13.11",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"alpinejs": "^3.14.8",
		"astro": "^5.17.0",
		"dotenv": "^16.4.7",
		"jquery": "^3.7.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sharp": "^0.33.5",
		"shiki": "^1.24.4",
		"sortablejs": "^1.15.6",
		"svelte": "^5.16.0",
		"tailwindcss": "^3.4.17",
		"vue": "^3.5.13"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/jquery": "^3.5.32",
		"@types/node": "^22.15.29",
		"@types/sortablejs": "^1.15.8",
		"@typescript-eslint/typescript-estree": "^8.60.1",
		"lint-staged": "^15.3.0",
		"markdownlint-cli2": "^0.22.1",
		"tsx": "^4.0.0",
		"typescript": "^5.7.2",
		"vercel": "^54.10.3"
	}
}
