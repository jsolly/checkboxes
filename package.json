{
	"name": "static-astro-website",
	"type": "module",
	"version": "0.0.1",
	"license": "MIT",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"prepare": "if [ -z \"$CI\" ] && git rev-parse --git-dir >/dev/null 2>&1; then git config core.hooksPath .git-hooks; fi",
		"lint": "biome lint .",
		"lint-fix": "biome lint --write .",
		"format": "biome format --write .",
		"check:biome": "biome check --write .",
		"check:ts": "astro check --minimumSeverity warning --minimumFailingSeverity warning",
		"check:md": "bash scripts/lint-md.sh",
		"check:yaml": "uvx yamllint@1.38.0 .",
		"generate-stats": "tsx src/utils/generate-stats.ts",
		"worktree:init": "bash scripts/worktree-init.sh; npm ci",
		"test": "tsx --test --test-reporter=dot \"tests/**/*.test.ts\"",
		"lint-staged": "lint-staged"
	},
	"lint-staged": {
		".agents/**": [],
		"!(.agents)/**/*": [
			"biome check --no-errors-on-unmatched --write"
		]
	},
	"overrides": {
		"path-to-regexp": ">=6.3.0",
		"tar-fs": ">=3.0.9",
		"brace-expansion": ">=2.0.2",
		"tar": ">=7.5.11",
		"defu": ">=6.1.5",
		"devalue": ">=5.3.2",
		"fast-uri": ">=3.1.1",
		"glob": ">=10.5.0",
		"lodash": ">=4.18.0",
		"minimatch": ">=9.0.6",
		"rollup": ">=4.59.0",
		"h3": ">=1.15.8",
		"picomatch": ">=2.3.2",
		"undici": ">=6.24.0",
		"vite": ">=8.0.13"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/react": "^6.0.1",
		"@astrojs/sitemap": "^3.7.3",
		"@astrojs/svelte": "^9.0.1",
		"@astrojs/vercel": "^11.0.2",
		"@astrojs/vue": "^7.0.1",
		"@google/genai": "^2.6.0",
		"@hotwired/stimulus": "^3.2.2",
		"@types/alpinejs": "^3.13.11",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"alpinejs": "^3.14.8",
		"astro": "^7.0.6",
		"dotenv": "^17.4.2",
		"jquery": "^4.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"sharp": "^0.35.3",
		"shiki": "^4.3.1",
		"sortablejs": "^1.15.6",
		"svelte": "^5.16.0",
		"tailwindcss": "^4.3.2",
		"vue": "^3.5.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@tailwindcss/vite": "^4.3.2",
		"@types/jquery": "^4.0.1",
		"@types/node": "^26.1.0",
		"@types/sortablejs": "^1.15.8",
		"@typescript-eslint/typescript-estree": "^8.63.0",
		"lint-staged": "^17.0.8",
		"markdownlint-cli2": "^0.23.0",
		"tsx": "^4.23.0",
		"typescript": "^6.0.3",
		"vercel": "^54.21.1"
	}
}
