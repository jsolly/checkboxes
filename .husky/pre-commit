#!/bin/sh
# BEGIN dotagents fleet pre-commit guard
ROOT="$(git rev-parse --show-toplevel)"
if [ -x "$ROOT/.agents/scripts/fleet-precommit-check.sh" ]; then
  bash "$ROOT/.agents/scripts/fleet-precommit-check.sh" || exit 1
fi
# END dotagents fleet pre-commit guard

echo "🚀 Running pre-commit hook..."
pnpm run lint-staged
lint_status=$?

if [ $lint_status -ne 0 ]; then
  echo "❌ Lint-staged failed! Please fix the errors and try committing again."
  exit $lint_status
fi

echo "Running Astro check..."
pnpm exec astro check

echo "Running production build..."
pnpm run build

echo "✅ Pre-commit hook completed successfully"
