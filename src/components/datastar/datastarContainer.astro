---
import datastarLogo from "../../assets/logos/datastar.svg";
import CodeBlock from "../shared/CodeBlock.astro";
import FrameworkContainer from "../shared/FrameworkContainer.astro";
import Datastar from "./datastar.astro";

const { default: code } = await import("./datastar.astro?raw");
---

<FrameworkContainer framework="datastar" title="Datastar">
  <Datastar />
  <CodeBlock code={code} displayName="Datastar" lang="html" logo={datastarLogo} />
</FrameworkContainer>